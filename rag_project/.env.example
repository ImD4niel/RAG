# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: github | openai | ollama | gemini
API_HOST=github

# GitHub Models (azure inference)
GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=gpt-4o-mini

# OpenAI (if API_HOST=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (if API_HOST=ollama)
OLLAMA_ENDPOINT=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Gemini (if API_HOST=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ── Vision ────────────────────────────────────────────────────────────────────
VISION_MODEL=gpt-4o

# ── Embedding ─────────────────────────────────────────────────────────────────
# Choose one: hf | openai | ollama | jina
EMBED_PROVIDER=hf
# IMPORTANT: Changing EMBED_MODEL requires a full re-index (drop documents table).
EMBED_MODEL=BAAI/bge-m3

# ── Reranking ─────────────────────────────────────────────────────────────────
# Choose one: hf | none
RERANK_PROVIDER=hf
RERANK_MODEL=BAAI/bge-reranker-base

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragdb
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Vector dimensions ─────────────────────────────────────────────────────────
# Must match EMBED_MODEL output dimension.
# BAAI/bge-m3 = 1024 | text-embedding-3-small = 1536 | CLIP-ViT-B/32 = 512
EMBEDDING_DIM=1024

# ── Performance ───────────────────────────────────────────────────────────────
# Max concurrent embedding / summarization API calls during indexing
EMBED_CONCURRENCY=8
# Max entries in the in-memory embedding cache (0 = unlimited, not recommended)
EMBED_CACHE_MAX=1000
